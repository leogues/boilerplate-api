{
  "name": "boilerplate-api",
  "version": "0.1.0",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot src/main.ts",
    "dev:debug": "bun --inspect --hot src/main.ts",
    "build": "bun build --compile --minify-whitespace --minify-syntax --sourcemap --outfile server src/main.ts",
    "typecheck": "tsc --noEmit",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome format .",
    "lint": "bunx biome lint .",
    "lint:fix": "bunx biome lint --fix .",
    "check": "bunx biome check .",
    "check:fix": "bunx biome check --fix .",
    "db:migrate": "bunx kysely migrate latest",
    "db:migrate:down": "bunx kysely migrate down",
    "db:migrate:make": "bunx kysely migrate make",
    "db:codegen": "bunx kysely-codegen --out-file src/shared/infra/persistence/types.ts",
    "fta": "bunx fta-cli src --format table",
    "fta:json": "bunx fta-cli src --json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@types/bun": "latest",
    "@types/pg": "^8.16.0",
    "kysely-codegen": "^0.20.0",
    "kysely-ctl": "^0.20.0",
    "lefthook": "^2.1.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/opentelemetry": "^1.4.10",
    "@elysiajs/server-timing": "^1.4.0",
    "@opentelemetry/instrumentation-pg": "^0.64.0",
    "elysia": "^1.4.25",
    "kysely": "^0.28.11",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-opentelemetry-transport": "^2.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "ulid": "^3.0.2"
  }
}
